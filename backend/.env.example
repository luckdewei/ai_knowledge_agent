
# 应用配置
APP_NAME=AI Knowledge Agent
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS 允许的前端地址
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# DeepSeek API (获取地址: platform.deepseek.com)
DEEPSEEK_API_KEY=sk-xxx

# 向量模型 API (硅基流动: cloud.siliconflow.cn)
EMBEDDING_API_KEY=sk-xxxx

# 数据库 (后续章节配置)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/knowledge_db

# Redis（docker compose 已提供；关闭则不走缓存）
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_EMBEDDING=604800
CACHE_TTL_STATS=60
CACHE_TTL_INSIGHTS=300

# Tavily 联网搜索 (https://tavily.com)
TAVILY_API_KEY=tvly-your-api-key

# JWT（租户登录，生产环境务必修改）
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRE_HOURS=168